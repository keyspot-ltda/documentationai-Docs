{
	"info": {
		"_postman_id": "keyspot-partner-api",
		"name": "Keyspot Partner API",
		"description": "API de integração para parceiros da Keyspot. Autenticação JWT em 2 fases: primeiro obtenha o token via POST /v1/auth/token, depois use-o como Bearer nas demais rotas.\n\nFiltros de data disponíveis em Properties e Leads: createdAfter, createdBefore, updatedAfter, updatedBefore (formato ISO 8601).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{access_token}}",
				"type": "string"
			}
		]
	},
	"variable": [],
	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"auth": { "type": "noauth" },
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["{{base_url}}"],
							"path": ["health"]
						},
						"description": "Verifica se a API está online. Não requer autenticação."
					},
					"response": [
						{
							"name": "200 - OK",
							"status": "OK",
							"code": 200,
							"header": [{ "key": "Content-Type", "value": "application/json" }],
							"body": "{\n  \"status\": \"ok\",\n  \"timestamp\": \"2026-03-13T10:00:00.000Z\"\n}"
						}
					]
				}
			]
		},
		{
			"name": "Auth",
			"item": [
				{
					"name": "Obter Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"if (pm.response.code === 200) {",
									"    const json = pm.response.json();",
									"    if (json.data && json.data.token) {",
									"        pm.environment.set('access_token', json.data.token);",
									"        console.log('Token salvo automaticamente!');",
									"    }",
									"}"
								]
							}
						}
					],
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{
								"key": "X-API-Key",
								"value": "{{api_key}}",
								"description": "Chave de API do parceiro"
							},
							{
								"key": "X-API-Secret",
								"value": "{{api_secret}}",
								"description": "Secret de API do parceiro"
							}
						],
						"url": {
							"raw": "{{base_url}}/v1/auth/token",
							"host": ["{{base_url}}"],
							"path": ["v1", "auth", "token"]
						},
						"description": "Fase 1 da autenticação. Envia as credenciais (X-API-Key e X-API-Secret) e recebe um JWT válido por 1 hora.\n\nO token é salvo automaticamente na variável access_token."
					},
					"response": [
						{
							"name": "200 - Token gerado",
							"status": "OK",
							"code": 200,
							"header": [{ "key": "Content-Type", "value": "application/json" }],
							"body": "{\n  \"data\": {\n    \"token\": \"eyJhbGciOiJIUzI1NiIs...\",\n    \"expiresIn\": 3600,\n    \"tokenType\": \"Bearer\"\n  }\n}"
						},
						{
							"name": "401 - Credenciais ausentes",
							"status": "Unauthorized",
							"code": 401,
							"header": [{ "key": "Content-Type", "value": "application/json" }],
							"body": "{\n  \"error\": \"X-API-Key and X-API-Secret headers are required\",\n  \"code\": \"MISSING_CREDENTIALS\"\n}"
						}
					]
				}
			]
		},
